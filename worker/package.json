{
  "name": "@gkit/sheets-api-worker",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "tsc --noEmit",
    "lint": "echo 'no lint configured' && exit 0",
    "db:local": "wrangler d1 execute sheetsapi --file=./schema.sql --local",
    "db:remote": "wrangler d1 execute sheetsapi --file=./schema.sql --remote"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.84.1"
  }
}
